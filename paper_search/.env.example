# PaperSearch standalone - example configuration
# Copy this file to `.env` and edit values.

# ----------------------------
# Result limits
# ----------------------------
PAPERSEARCH_PER_PLATFORM_LIMIT=10
PAPERSEARCH_FINAL_LIMIT=10
PAPERSEARCH_FINAL_LIMIT_MAX=50

# Platform-specific limits (optional)
# One-line mapping (can be mixed with per-platform overrides; per-platform overrides win)
# PAPERSEARCH_PLATFORM_LIMITS=arxiv=10,openalex=5,pubmed=10
# Explicit per-platform overrides
# PAPERSEARCH_PLATFORM_LIMIT_OPENALEX=10
# PAPERSEARCH_PLATFORM_LIMIT_SEMANTICSCHOLAR=10
# PAPERSEARCH_PLATFORM_LIMIT_ARXIV=10
# PAPERSEARCH_PLATFORM_LIMIT_PUBMED=10
# PAPERSEARCH_PLATFORM_LIMIT_CROSSREF=10
# PAPERSEARCH_PLATFORM_LIMIT_INFOXMED=10
# PAPERSEARCH_PLATFORM_LIMIT_IEEE=10

# Request guards (optional; set 0 to disable)
PAPERSEARCH_QUERY_MAX_CHARS=512
PAPERSEARCH_PLATFORMS_MAX=10

# ----------------------------
# Contact identity (recommended)
# ----------------------------
# Some public APIs strongly recommend providing a contact email.
PAPERSEARCH_CONTACT_EMAIL=
# Optional multi-email pool (comma-separated). When multiple emails are provided, PaperSearch will pick one per request.
# PAPERSEARCH_CONTACT_EMAILS=you@example.com,alt@example.com
PAPERSEARCH_TOOL_NAME=papersearch

# Email selection strategy for email pools:
# - round_robin (default)
# - random
# - first
PAPERSEARCH_EMAIL_PICK_STRATEGY=round_robin

# Optional per-service mailto/email pools (comma-separated; fallback to contact email pool)
PAPERSEARCH_OPENALEX_MAILTO=
PAPERSEARCH_OPENALEX_MAILTOS=
PAPERSEARCH_CROSSREF_MAILTO=
PAPERSEARCH_CROSSREF_MAILTOS=
PAPERSEARCH_UNPAYWALL_EMAIL=
PAPERSEARCH_UNPAYWALL_EMAILS=

# ----------------------------
# Platform API Keys (optional but recommended where applicable)
# ----------------------------
PAPERSEARCH_SEMANTICSCHOLAR_API_KEY=
PAPERSEARCH_NCBI_API_KEY=
PAPERSEARCH_CORE_API_KEY=
PAPERSEARCH_IEEE_API_KEY=

# IEEE Xplore rate limit (default: 10 calls/s, 200 calls/day)
PAPERSEARCH_IEEE_PER_SECOND_LIMIT=10
PAPERSEARCH_IEEE_DAILY_LIMIT=200

# ----------------------------
# InfoXMed (optional)
# 0=all, 1=PubMed, 2=guidelines, 3=zh_journal
# ----------------------------
PAPERSEARCH_INFOXMED_CATEGORY=0
PAPERSEARCH_INFOXMED_FIELD=
PAPERSEARCH_INFOXMED_FILTER=
PAPERSEARCH_INFOXMED_SORT=

# ----------------------------
# LLM (OpenAI-compatible) - optional
# Used for:
# - embeddings ranking (PAPERSEARCH_EMBED_MODELNAME)
# - rerank endpoint (PAPERSEARCH_RERANK_MODELNAME)
# - Chinese summary / relevance remark (PAPERSEARCH_SUMMARY_MODELNAME)
# ----------------------------
PAPERSEARCH_LLM_BASEURL=
PAPERSEARCH_LLM_APIKEY=
PAPERSEARCH_RANK_MODELNAME=
PAPERSEARCH_EMBED_MODELNAME=
PAPERSEARCH_RERANK_MODELNAME=
PAPERSEARCH_SUMMARY_MODELNAME=

# LLM retry / concurrency (optional)
PAPERSEARCH_LLM_MAX_CONCURRENCY=1
PAPERSEARCH_LLM_MAX_RETRIES=5
PAPERSEARCH_LLM_RETRY_BASE_DELAY=1.0
PAPERSEARCH_LLM_RETRY_MAX_DELAY=30.0

# Rerank controls (optional)
PAPERSEARCH_RERANK_TIMEOUT_S=30.0
PAPERSEARCH_RERANK_MAX_RETRIES=1
PAPERSEARCH_RERANK_MAX_DOC_CHARS=2000

# Summary behavior controls (optional)
# NOTE: if enabled but LLM is not configured, `agent_remark` will be an empty string.
PAPERSEARCH_SUMMARY_ENABLED=0
PAPERSEARCH_SUMMARY_MAX_CONCURRENCY=1
PAPERSEARCH_SUMMARY_BATCH_SIZE=1
PAPERSEARCH_SUMMARY_MAX_PAPERS=10
PAPERSEARCH_SUMMARY_ABSTRACT_MAX_CHARS=3000

# ----------------------------
# OA PDF discovery / DOI enrichment (optional)
# ----------------------------
PAPERSEARCH_OA_MAX_CONCURRENCY=5
PAPERSEARCH_DOI_ENRICH_ENABLED=1
PAPERSEARCH_DOI_ENRICH_TIMEOUT_S=5.0
PAPERSEARCH_DOI_ENRICH_MAX_CONCURRENCY=2

# ----------------------------
# Storage (optional)
# ----------------------------
PAPERSEARCH_STORAGE_DIR=storage

# ----------------------------
# Debug (optional)
# ----------------------------
PAPERSEARCH_DEBUG=0

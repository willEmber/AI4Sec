# PaperSearch standalone - example configuration
# Copy this file to `.env` and edit values.

# ----------------------------
# Result limits
# ----------------------------
PAPERSEARCH_PER_PLATFORM_LIMIT=10
PAPERSEARCH_FINAL_LIMIT=10
PAPERSEARCH_FINAL_LIMIT_MAX=50

# Platform-specific limits (optional)
# One-line mapping (can be mixed with per-platform overrides; per-platform overrides win)
# PAPERSEARCH_PLATFORM_LIMITS=arxiv=10,openalex=5,pubmed=10
# Explicit per-platform overrides
# PAPERSEARCH_PLATFORM_LIMIT_OPENALEX=10
# PAPERSEARCH_PLATFORM_LIMIT_SEMANTICSCHOLAR=10
# PAPERSEARCH_PLATFORM_LIMIT_GOOGLESCHOLAR=10
# PAPERSEARCH_PLATFORM_LIMIT_ARXIV=10
# PAPERSEARCH_PLATFORM_LIMIT_PUBMED=10
# PAPERSEARCH_PLATFORM_LIMIT_CROSSREF=10
# PAPERSEARCH_PLATFORM_LIMIT_INFOXMED=10

# Request guards (optional; set 0 to disable)
PAPERSEARCH_QUERY_MAX_CHARS=512
PAPERSEARCH_PLATFORMS_MAX=10

# ----------------------------
# Contact identity (recommended)
# ----------------------------
# Some public APIs strongly recommend providing a contact email.
PAPERSEARCH_CONTACT_EMAIL=
# Optional multi-email pool; the first non-empty email will be used.
# PAPERSEARCH_CONTACT_EMAILS=you@example.com,alt@example.com
PAPERSEARCH_TOOL_NAME=papersearch

# Optional per-service mailto/email (fallback to PAPERSEARCH_CONTACT_EMAIL)
PAPERSEARCH_CONTACT_EMAILS=chen.weiting.92@gmail.com, liam.w_design@outlook.com, sunny.wang0512@gmail.com, jessica_lynn88@gmail.com, lucas.ucla.2024@gmail.com, alice_wang_std@outlook.com, h.takahashi@proton.me, dev.marco@gmail.com, m.zhang_consulting@gmail.com, shanghai_mike@outlook.com
PAPERSEARCH_OPENALEX_MAILTO=chen.weiting.92@gmail.com, liam.w_design@outlook.com, sunny.wang0512@gmail.com, jessica_lynn88@gmail.com, lucas.ucla.2024@gmail.com, alice_wang_std@outlook.com, h.takahashi@proton.me, dev.marco@gmail.com, m.zhang_consulting@gmail.com, shanghai_mike@outlook.com

PAPERSEARCH_CROSSREF_MAILTO=chen.weiting.92@gmail.com, liam.w_design@outlook.com, sunny.wang0512@gmail.com, jessica_lynn88@gmail.com, lucas.ucla.2024@gmail.com, alice_wang_std@outlook.com, h.takahashi@proton.me, dev.marco@gmail.com, m.zhang_consulting@gmail.com, shanghai_mike@outlook.com

PAPERSEARCH_UNPAYWALL_EMAIL=chen.weiting.92@gmail.com, liam.w_design@outlook.com, sunny.wang0512@gmail.com, jessica_lynn88@gmail.com, lucas.ucla.2024@gmail.com, alice_wang_std@outlook.com, h.takahashi@proton.me, dev.marco@gmail.com, m.zhang_consulting@gmail.com, shanghai_mike@outlook.com


# ----------------------------
# Platform API Keys (optional but recommended where applicable)
# ----------------------------
PAPERSEARCH_SEMANTICSCHOLAR_API_KEY=NKP94n9fGya6OEpmnzDhrDYNfSHtpFy3Y9uV1cU2
PAPERSEARCH_NCBI_API_KEY=f5c2ea285edf226ec89b281394c5c4ae2508
PAPERSEARCH_CORE_API_KEY=5Lhg20PeNmGzE7jk96vVKnIbD3BiuxHs
PAPERSEARCH_IEEE_API_KEY=89tv2zcz9h5wrcu8h7xcty3g
# ----------------------------
# InfoXMed (optional)
# 0=all, 1=PubMed, 2=guidelines, 3=zh_journal
# ----------------------------
PAPERSEARCH_INFOXMED_CATEGORY=0
PAPERSEARCH_INFOXMED_FIELD=
PAPERSEARCH_INFOXMED_FILTER=
PAPERSEARCH_INFOXMED_SORT=

# ----------------------------
# LLM (OpenAI-compatible) - optional
# Used for:
# - embeddings ranking (PAPERSEARCH_EMBED_MODELNAME)
# - rerank endpoint (PAPERSEARCH_RERANK_MODELNAME)
# - Chinese summary / relevance remark (PAPERSEARCH_SUMMARY_MODELNAME)
# ----------------------------
PAPERSEARCH_LLM_BASEURL=https://api.siliconflow.cn/v1
PAPERSEARCH_LLM_APIKEY=sk-oteswlfxxafegewkhvewkmxxeokurllckwnsjvhnwifkmkfa
PAPERSEARCH_RANK_MODELNAME=Qwen/Qwen3-Reranker-8B
PAPERSEARCH_EMBED_MODELNAME=Qwen/Qwen3-Embedding-8B
PAPERSEARCH_RERANK_MODELNAME=Qwen/Qwen3-Reranker-8B
PAPERSEARCH_SUMMARY_MODELNAME=deepseek-ai/DeepSeek-V3.2

# LLM retry / concurrency (optional)
PAPERSEARCH_LLM_MAX_CONCURRENCY=1
PAPERSEARCH_LLM_MAX_RETRIES=5
PAPERSEARCH_LLM_RETRY_BASE_DELAY=1.0
PAPERSEARCH_LLM_RETRY_MAX_DELAY=30.0

# Rerank controls (optional)
PAPERSEARCH_RERANK_TIMEOUT_S=30.0
PAPERSEARCH_RERANK_MAX_RETRIES=1
PAPERSEARCH_RERANK_MAX_DOC_CHARS=2000

# Summary behavior controls (optional)
# NOTE: if enabled but LLM is not configured, `agent_remark` will be an empty string.
PAPERSEARCH_SUMMARY_ENABLED=0
PAPERSEARCH_SUMMARY_MAX_CONCURRENCY=1
PAPERSEARCH_SUMMARY_BATCH_SIZE=1
PAPERSEARCH_SUMMARY_MAX_PAPERS=10
PAPERSEARCH_SUMMARY_ABSTRACT_MAX_CHARS=3000

# ----------------------------
# OA PDF discovery / DOI enrichment (optional)
# ----------------------------
PAPERSEARCH_OA_MAX_CONCURRENCY=5
PAPERSEARCH_DOI_ENRICH_ENABLED=1
PAPERSEARCH_DOI_ENRICH_TIMEOUT_S=5.0
PAPERSEARCH_DOI_ENRICH_MAX_CONCURRENCY=2

# ----------------------------
# Storage (optional)
# ----------------------------
# PAPERSEARCH_STORAGE_DIR=storage
# PAPERSEARCH_INTERNAL_PDF_URL_TEMPLATE=/rootAgent/api/download_paper?doi={doi}
# PAPERSEARCH_INTERNAL_PDF_URL_NO_DOI_TEMPLATE=/rootAgent/api/download_paper?title_hash={title_hash}

# ----------------------------
# Debug (optional)
# ----------------------------
PAPERSEARCH_DEBUG=0

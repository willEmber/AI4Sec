# === LLM (Qwen Responses API) ===
LLM_BASEURL="https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1"
LLM_APIKEY="your-api-key"
THINKING_MODELNAME=your-model-name
EMBED_MODELNAME=your-embed-model
RERANK_MODELNAME=your-rerank-model

# === MinerU PDF Parsing ===
MINERU_TOKEN="your-mineru-token"

# === PublicationRank / EasyScholar ===
EASYSCHOLAR_SECRET_KEY="your-easyscholar-secret-key"
# EASYSCHOLAR_API_URL="https://www.easyscholar.cc/open/getPublicationRank"

# === Research Sphere (optional) ===
# SPHERE_RADIUS=1
# SPHERE_CANDIDATE_CAP=200
# SPHERE_LAYER1_CAP=40
# SPHERE_PDF_PARSE_CAP=0

# === Docker registry mirror (optional, for China mainland) ===
# REGISTRY_MIRROR=docker.1ms.run

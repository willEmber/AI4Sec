# Backend Docker build context filter.
# Only backend/, paper_search/, and PublicationRank/ are needed.

.git/
frontend/
docker-data/
papersdownload/
paper_converter/
test_doc/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets (injected at runtime via env_file)
.env
.env.local
.env.example

# Logs
*.log
